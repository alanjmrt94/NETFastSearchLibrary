# Plantilla de variables para scripts/release.ps1
# Copie a release.env (gitignored) y complete los valores.

# Ruta al strong-name (opcional; default: NETFastSearchLibrary/EMZApps.snk)
# EMZAPPS_SNK_PATH=NETFastSearchLibrary\EMZApps.snk

# --- Obligatorio para publicar en nuget.org ---
NUGET_API_KEY=

# --- Opcional: NuGet Author Signing (Authenticode). Sin esto, nuget.org firma el repositorio. ---
# NUGET_SIGN_CERT_PFX=C:\ruta\codigo-firma-emzapps.pfx
# NUGET_SIGN_CERT_PASSWORD=su-contraseña
